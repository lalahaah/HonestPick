# HonestPick 환경변수 템플릿
# 이 파일을 복사해서 .env.local로 저장하고 실제 값을 채워주세요
# .env.local은 .gitignore에 포함되어 있어 커밋되지 않습니다

# Supabase — Dashboard > Project Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # 절대 공개 금지!

# Resend — Phase 4 구독 폼 연동 시 필요
# RESEND_API_KEY=re_your_api_key_here

# Amazon Associates — Phase 4 승인 완료 후 추가
# AMAZON_ASSOCIATE_TAG=honestpick-20
